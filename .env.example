# Core recipient
CONTACT_TO_EMAIL=your-email@gmail.com

# Optional explicit sender (recommended for non-Gmail SMTP)
# CONTACT_FROM_EMAIL=Portfolio Contact <your-email@gmail.com>

# Contact API + security
CONTACT_ALLOWED_ORIGINS=http://localhost:5173,https://keithfbuilds.dev,https://www.keithfbuilds.dev
CONTACT_IP_HASH_SALT=replace-with-long-random-hex

# Optional Resend provider (primary if configured)
# RESEND_API_KEY=re_xxxxx

# Free Gmail fallback (works with App Password + 2FA)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional generic SMTP fallback (if not using Gmail)
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-user
# SMTP_PASS=your-pass

# Optional distributed limits + counters
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# CONTACT_SUMMARY_RETENTION_DAYS=30
# ADMIN_SUMMARY_KEY=replace-with-strong-admin-key

# Optional frontend endpoint overrides
# VITE_CONTACT_ENDPOINT=/api/contact
# VITE_CONTACT_ANALYTICS_ENDPOINT=/api/contact-analytics
